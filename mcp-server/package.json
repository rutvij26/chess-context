{
  "name": "mcp-chess",
  "version": "0.7.0",
  "description": "ChessContext MCP — semantic chess intelligence for Claude",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-chess": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/store/schema.sql', 'dist/store/schema.sql')\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.8.0",
    "chess.js": "^1.3.0",
    "lru-cache": "^11.1.0",
    "postgres": "^3.4.8",
    "stockfish": "^18.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "chess",
    "mcp",
    "claude",
    "stockfish",
    "model-context-protocol"
  ],
  "license": "MIT"
}
